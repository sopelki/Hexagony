{
    "m_SGVersion": 1,
    "m_Type": "UnityEditor.ShaderGraph.CustomFunctionNode",
    "m_ObjectId": "0846a189350a46d4a00fe9c779cb4991",
    "m_Group": {
        "m_Id": ""
    },
    "m_Name": "HexGrid (Custom Function)",
    "m_DrawState": {
        "m_Expanded": true,
        "m_Position": {
            "serializedVersion": "2",
            "x": -350.3999938964844,
            "y": -281.6000061035156,
            "width": 201.60000610351563,
            "height": 100.79998779296875
        }
    },
    "m_Slots": [
        {
            "m_Id": "d260abe6ba854d88975ed55f4b03d2cc"
        },
        {
            "m_Id": "13c486f9032e451ba6ec429d8bf20361"
        },
        {
            "m_Id": "894e043e827b48f59d9575ac4cfce48c"
        },
        {
            "m_Id": "b3ccad223e7b4cbb9ebab1e80c570a50"
        },
        {
            "m_Id": "b9ace02e661847478b21b3b0b058d85e"
        },
        {
            "m_Id": "398d164713ec4d1db41a211ba5323ed9"
        }
    ],
    "synonyms": [
        "code",
        "HLSL"
    ],
    "m_Precision": 0,
    "m_PreviewExpanded": false,
    "m_DismissedVersion": 0,
    "m_PreviewMode": 0,
    "m_CustomColors": {
        "m_SerializableColors": []
    },
    "m_SourceType": 1,
    "m_FunctionName": "HexGrid",
    "m_FunctionSource": "",
    "m_FunctionSourceUsePragmas": true,
    "m_FunctionBody": "// Входы: float2 UV, float Scale, float Aspect\r\n// Выходы: float HexDist, float2 HexUV, float2 HexID\r\n\r\n// 1. Корректируем UV по Aspect Ratio, чтобы гексы не тянулись\r\nfloat2 p = UV * Scale;\r\np.x *= Aspect; // Умножаем X на соотношение сторон (например, 1.77 для 16:9)\r\n\r\n// 2. Осевые координаты (Pointy Top)\r\nfloat2 q = float2((sqrt(3.0)/3.0 * p.x - 1.0/3.0 * p.y), (2.0/3.0 * p.y));\r\n\r\n// 3. Кубические координаты\r\nfloat3 cube = float3(q.x, q.y, -q.x - q.y);\r\n\r\n// 4. Округление\r\nfloat3 r = floor(cube + 0.5);\r\nfloat3 diff = abs(r - cube);\r\nif (diff.x > diff.y && diff.x > diff.z) r.x = -r.y - r.z;\r\nelse if (diff.y > diff.z) r.y = -r.x - r.z;\r\nelse r.z = -r.x - r.y;\r\n\r\nHexID = r.xy;\r\n\r\n// 5. Центр и локальные координаты\r\nfloat2 center;\r\ncenter.x = (sqrt(3.0) * r.x + sqrt(3.0)/2.0 * r.y);\r\ncenter.y = (1.5 * r.y);\r\n\r\nfloat2 localPos = p - center;\r\nHexUV = localPos;\r\n\r\n// 6. SDF (расстояние до краев)\r\nfloat2 a = abs(localPos);\r\n// 0.866025 - это идеальный радиус вписанной окружности\r\nHexDist = max(a.y, a.x * 0.866025 + a.y * 0.5);"
}

